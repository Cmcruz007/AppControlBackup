{
  "name": "backup-monitor",
  "version": "1.0.0",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "build:win": "npm run build && electron-builder --win dir"
  },
  "dependencies": {
    "express": "^5.2.1",
    "mssql": "^10.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "undici": "^8.5.0",
    "xlsx-js-style": "^1.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^30.0.0",
    "electron-builder": "^24.0.0",
    "vite": "^5.0.0"
  },
  "build": {
    "appId": "com.uci.backupmonitor",
    "productName": "BackupMonitor",
    "directories": {
      "output": "release"
    },
    "win": {
      "target": [
        "dir"
      ]
    },
    "files": [
      "dist/**/*",
      "main.cjs",
      "preload.cjs"
    ]
  }
}
