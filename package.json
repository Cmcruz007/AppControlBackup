{
  "name": "backup-monitor",
  "private": true,
  "version": "1.0.0",
  "main": "electron/main.cjs",
  "scripts": {
    "dev:vite": "vite",
    "build": "vite build",
    "start": "electron .",
    "package:win": "vite build && electron-packager . BackupMonitor --platform=win32 --arch=x64 --out=release --overwrite --prune=true --ignore=\"^/src$\" --ignore=\"^/release\" --ignore=\"^/\\.vscode\" --ignore=\"^/tsconfig\\.json$\" --ignore=\"^/vite\\.config\" --ignore=\"^/index\\.html$\"",
    "package:linux": "vite build && electron-packager . BackupMonitor --platform=linux --arch=x64 --out=release --overwrite --prune=true --ignore=\"^/src$\" --ignore=\"^/release\""
  },
  "dependencies": {
    "mssql": "^11.0.1",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.2.0",
    "electron-packager": "^17.1.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
